{
  "id": "openclaw-flowmail",
  "name": "FlowMail",
  "description": "Turn business email into persistent workflows using gog-backed Gmail polling, local state, and business case packs inside OpenClaw.",
  "version": "0.1.0",
  "skills": [
    "./skills"
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "gmailAccount": {
        "type": "string"
      },
      "gogPath": {
        "type": "string",
        "default": "gog"
      },
      "listCommandTemplate": {
        "type": "string",
        "default": "gog gmail search --account \"{{gmailAccount}}\" --query \"{{syncQuery}}\" --limit {{maxThreads}} --json"
      },
      "threadCommandTemplate": {
        "type": "string",
        "default": "gog gmail get \"{{threadId}}\" --account \"{{gmailAccount}}\" --json"
      },
      "syncQuery": {
        "type": "string",
        "default": "newer_than:30d -category:promotions -category:social -category:forums -category:updates"
      },
      "casePackId": {
        "type": "string",
        "enum": [
          "external_trade_order",
          "saas_revenue_order"
        ],
        "default": "external_trade_order"
      },
      "maxThreads": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100,
        "default": 25
      },
      "pollIntervalMinutes": {
        "type": "integer",
        "minimum": 1,
        "maximum": 1440,
        "default": 10
      },
      "autoPoll": {
        "type": "boolean",
        "default": true
      },
      "stateDir": {
        "type": "string"
      }
    }
  },
  "uiHints": {
    "labels": {
      "gmailAccount": "Gmail account",
      "gogPath": "gog binary path",
      "listCommandTemplate": "List command template",
      "threadCommandTemplate": "Thread detail command template",
      "syncQuery": "Gmail sync query",
      "casePackId": "Workflow template",
      "maxThreads": "Max threads per sync",
      "pollIntervalMinutes": "Poll interval (minutes)",
      "autoPoll": "Enable background polling",
      "stateDir": "State directory"
    },
    "placeholders": {
      "gmailAccount": "work@example.com",
      "stateDir": "~/.openclaw/state/openclaw-flowmail"
    }
  }
}
